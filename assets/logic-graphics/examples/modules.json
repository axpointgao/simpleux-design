    { "id": "输出层", "title": "输出层" }
  ],
  "nodes": [
    { "id": "brief", "group": "输入层", "kind": "rect", "title": "任务意图", "body": "目标、受众、内容" },
    { "id": "asset", "group": "输入层", "kind": "rect", "title": "参考资产", "body": "品牌、截图、图库" },
    { "id": "component", "group": "处理层", "kind": "rect", "title": "组件选择", "body": "节点、分组、连接线", "emphasis": true, "badge": "关键" },
    { "id": "layout", "group": "处理层", "kind": "rect", "title": "布局约束", "body": "安全区和容量" },
    { "id": "html", "group": "输出层", "kind": "rect", "title": "HTML 图形", "body": "可嵌入 deck" },
